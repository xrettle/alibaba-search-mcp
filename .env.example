# Server Configuration
PORT=3000

# Concurrency & Scraping Queue Limits
MAX_CONCURRENCY=2

# In-Memory Cache TTL (seconds) - Default is 1800 (30 minutes)
CACHE_TTL_SECONDS=1800

# Playwright request timeout in milliseconds
REQUEST_TIMEOUT_MS=30000

# Scraper Retries
MAX_RETRIES=2

# Security (Optional Bearer Token)
# Leave empty to allow open access. If defined, client requests must present this token.
# Perplexity Custom Connectors support custom headers (e.g., Authorization: Bearer <token>).
MCP_BEARER_TOKEN=
